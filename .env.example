# Copy this file to a file named ".env" (in the same folder you run the tool
# from) and paste your key below. Never commit your real .env file.
#
# A free TheTVDB v4 API key is available at:
#   https://thetvdb.com/api-information
#
# When a key is present, the tool fills in series descriptions and genres and
# the full season/episode list for every show, then overlays the real watched
# status recovered from your backup. Without a key the tool still works, it just
# uses whatever the backup itself contained.

TVDB_API_KEY=

# Only needed for user-supported (subscriber) keys. Leave blank for a normal
# project API key.
TVDB_PIN=
